{
  "name": "freestuff",
  "version": "2.3.0-rc.8",
  "description": "An API wrapper for the FreeStuff API",
  "homepage": "https://docs.freestuffbot.xyz/libraries/node",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "default": "./dist/parser.js"
    },
    "./hono": {
      "types": "./dist/plugins/hono.d.ts",
      "default": "./dist/plugins/hono.js"
    },
    "./express": {
      "types": "./dist/plugins/express.d.ts",
      "default": "./dist/plugins/express.js"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:bun": "bun build ./src/index.ts ./src/parser.ts ./src/plugins/hono.ts ./src/plugins/express.ts --root ./src --outdir ./dist --packages=external --target=node --sourcemap=linked --splitting",
    "build:tsc": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "build": "bun run build:bun && bun run build:tsc",
    "prepublishOnly": "bun run build",
    "publish:npm": "npm publish --provenance --access public"
  },
  "author": {
    "name": "Andreas May",
    "email": "andreas@maanex.me",
    "url": "https://maanex.me/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FreeStuffBot/api-wrapper-nodejs"
  },
  "license": "ISC",
  "dependencies": {
    "axios": "^0.21.1",
    "express": "^5.1.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "hono": "^4.9.8"
  }
}
